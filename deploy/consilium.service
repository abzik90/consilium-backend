[Unit]
Description=Consilium Backend
After=network.target

[Service]
User=__APP_USER__
Group=__APP_GROUP__
WorkingDirectory=__BACKEND_DIR__
EnvironmentFile=__ENV_FILE__
ExecStart=__VENV_DIR__/bin/uvicorn app.main:app --host __APP_HOST__ --port __APP_PORT__
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target